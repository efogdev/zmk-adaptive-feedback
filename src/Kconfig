config ZMK_ADAPTIVE_RGB
    bool "Adaptive RGB"
    select LED_STRIP
    default y

if ZMK_ADAPTIVE_RGB

config ZMK_ADAPTIVE_RGB_MAX_COLORS
    int "Maximum number of colors per event entry"
    default 8
    range 1 16

config ZMK_ADAPTIVE_RGB_BATT_WARN_THRESH_1
    int "Battery warning threshold 1 (%)"
    default 30
    range 0 100

config ZMK_ADAPTIVE_RGB_BATT_WARN_THRESH_2
    int "Battery warning threshold 2 (%)"
    default 25
    range 0 100

config ZMK_ADAPTIVE_RGB_BATT_WARN_THRESH_3
    int "Battery warning threshold 3 (%)"
    default 20
    range 0 100

config ZMK_ADAPTIVE_RGB_BATT_CRIT_THRESH_1
    int "Battery critical threshold 1 (%)"
    default 15
    range 0 100

config ZMK_ADAPTIVE_RGB_BATT_CRIT_THRESH_2
    int "Battery critical threshold 2 (%)"
    default 10
    range 0 100

config ZMK_ADAPTIVE_RGB_BATT_CRIT_THRESH_3
    int "Battery critical threshold 3 (%)"
    default 5
    range 0 100

config ZMK_ADAPTIVE_RGB_TICK_MS
    int "Animation tick interval in milliseconds"
    default 50
    range 16 500

config ZMK_ADAPTIVE_RGB_BRIGHTNESS
    int "Global brightness (0-100%)"
    default 100
    range 0 100

endif

rsource "shell/Kconfig"
